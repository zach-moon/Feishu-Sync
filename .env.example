# ============================================================
# FeiSync 配置文件
# 复制为 .env 后填入实际值：cp .env.example .env
# ============================================================

# ─── 必填：飞书多维表格 ────────────────────────────────────
# 直接粘贴飞书表的完整 URL（脚本自动解析）
FEISHU_TABLE_URL="https://xxx.feishu.cn/base/bascnXXX?table=tblXXX"

# ─── 必填：目标 Git 仓库 ───────────────────────────────────
# 支持 GitLab、GitHub 或任何 git 仓库（SSH 或 HTTPS）
GIT_REPO_URL=git@gitlab.example.com:group/project.git
GIT_BRANCH=main

# 示例：
# GIT_REPO_URL=git@github.com:your-org/your-project.git
# GIT_REPO_URL=https://github.com/your-org/your-project.git
# GIT_REPO_URL=git@gitlab.hirobot.in:cloud/sproboagent.git

# 或者用本地已有仓库路径（二选一，GIT_REPO_URL 优先）
# REPO_ROOT=/path/to/local/repo

# ─── 可选：运行模式 ────────────────────────────────────────
DRY_RUN=false
FORCE_SYNC=false
REMOVED_PROTECTION_THRESHOLD=0.30

# ─── 可选：CSV 诊断输出 ────────────────────────────────────
# CSV_OUTPUT_PATH=/tmp/feisync-preview.csv

# ─── 可选：Spec 路径 ──────────────────────────────────────
# 默认扫描 .kiro/specs，可改为任意相对路径
# SPECS_PATH=.kiro/specs

# ─── 可选：日报发送 ────────────────────────────────────────
# 飞书群 chat_id（通过 lark-cli im +chat-list 获取）
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
