# ============================================================
# FeiSync 配置文件
# 复制为 .env 后填入实际值
# ============================================================

# ─── 必填：飞书多维表格 ────────────────────────────────────
# 直接粘贴飞书表的完整 URL 即可（脚本自动解析 APP_TOKEN 和 TABLE_ID）
FEISHU_TABLE_URL=https://ncnpm83tnodo.feishu.cn/base/S1q9bZqjBad1e4sNUWdcI7Mknah?table=tblhj5yRqMvPyLGQ

# 或者分开填（如果设置了 FEISHU_TABLE_URL 则忽略下面两个）
# FEISHU_APP_TOKEN=
# FEISHU_TABLE_ID=

# ─── 必填：目标仓库 ────────────────────────────────────────
# 方式 A：本地路径（已 clone 的仓库，定时任务会自动 git pull）
REPO_ROOT=/path/to/your/project

# 方式 B：GitLab 仓库 URL（脚本会自动 clone 到临时目录）
# 如果设置了 GITLAB_REPO_URL，则忽略 REPO_ROOT
# GITLAB_REPO_URL=https://gitlab.example.com/group/project.git
# GITLAB_BRANCH=main

# ─── 可选：运行模式 ────────────────────────────────────────
# DRY_RUN=true        → 只扫描解析，不写飞书（用于调试）
# FORCE_SYNC=true     → 跳过移除保护阈值（用于首次接入或修复）
DRY_RUN=false
FORCE_SYNC=false

# ─── 可选：安全阈值 ────────────────────────────────────────
# 单次同步中如果超过该比例的任务将被标记为"已移除"，脚本会中止
# 防止误操作导致飞书表大面积失真
REMOVED_PROTECTION_THRESHOLD=0.30

# ─── 可选：CSV 诊断输出 ────────────────────────────────────
# 设置后每次同步会额外输出一份 CSV 文件，方便排查解析结果
# CSV_OUTPUT_PATH=/tmp/feisync-preview.csv
